---
# OpenTelemetry Collector Gateway Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

extensions:
  health_check:
    endpoint: "{{ otel_gateway_listen_host }}:{{ otel_gateway_health_port }}"

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: "{{ otel_gateway_listen_host }}:{{ otel_gateway_otlp_grpc_port }}"
{% if otel_gateway_tls_enabled %}
        tls:
          cert_file: "{{ otel_gateway_tls_cert }}"
          key_file: "{{ otel_gateway_tls_key }}"
{% if otel_gateway_tls_ca %}
          ca_file: "{{ otel_gateway_tls_ca }}"
{% endif %}
{% endif %}
      http:
        endpoint: "{{ otel_gateway_listen_host }}:{{ otel_gateway_otlp_http_port }}"
{% if otel_gateway_tls_enabled %}
        tls:
          cert_file: "{{ otel_gateway_tls_cert }}"
          key_file: "{{ otel_gateway_tls_key }}"
{% if otel_gateway_tls_ca %}
          ca_file: "{{ otel_gateway_tls_ca }}"
{% endif %}
{% endif %}

processors:
  memory_limiter:
    check_interval: 2s
    limit_mib: {{ otel_gateway_memory_limit_mib }}
    spike_limit_mib: {{ otel_gateway_memory_spike_limit_mib }}

  batch:
    timeout: {{ otel_gateway_batch_timeout }}
    send_batch_size: {{ otel_gateway_batch_send_size }}

exporters:
{% for exporter in otel_gateway_exporters %}
  {{ exporter.name }}:
    endpoint: "{{ exporter.endpoint }}"
{% if exporter.token is defined %}
    token: "{{ exporter.token }}"
{% endif %}
{% if exporter.tls_insecure_skip_verify is defined %}
    tls:
      insecure_skip_verify: {{ exporter.tls_insecure_skip_verify | lower }}
{% endif %}
{% if exporter.timeout is defined %}
    timeout: {{ exporter.timeout }}
{% endif %}
{% if exporter.headers is defined %}
    headers:
{% for key, value in exporter.headers.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% endfor %}

service:
  extensions: [health_check]

  pipelines:
    traces:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: [{% for exporter in otel_gateway_exporters %}{{ exporter.name }}{% if not loop.last %}, {% endif %}{% endfor %}]

    metrics:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: [{% for exporter in otel_gateway_exporters %}{{ exporter.name }}{% if not loop.last %}, {% endif %}{% endfor %}]

    logs:
      receivers: [otlp]
      processors: [memory_limiter, batch]
      exporters: [{% for exporter in otel_gateway_exporters %}{{ exporter.name }}{% if not loop.last %}, {% endif %}{% endfor %}]
